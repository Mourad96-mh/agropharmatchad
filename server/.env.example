# --- Serveur ---
PORT=4000
# Origines autorisées (CORS), séparées par des virgules — front local + domaine de prod
CORS_ORIGIN=http://localhost:3000,https://agropharmatchad.com

# --- MongoDB Atlas ---
# Récupéré dans Atlas > Database > Connect > Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/agropharma?retryWrites=true&w=majority

# --- Authentification ---
# Chaîne longue et aléatoire (ex: openssl rand -base64 48)
JWT_SECRET=remplacez-par-une-longue-chaine-aleatoire

# --- Cloudinary (Dashboard > Account Details) ---
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# --- Publication ---
# Le site public lit le contenu en direct depuis cette API (runtime fetch) : les modifications
# de l'admin sont visibles immédiatement, sans reconstruction. Aucune variable nécessaire ici.

# --- Compte administrateur (utilisé par le script de seed) ---
ADMIN_EMAIL=admin@agropharmatchad.com
ADMIN_PASSWORD=choisissez-un-mot-de-passe-fort
