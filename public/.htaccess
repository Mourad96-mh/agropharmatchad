# AGROPHARMA TCHAD — hébergement statique (Hostinger / Apache)
# Le site est un export statique Next.js (URLs sans slash final, ex: /produits/semences-maraicheres)

RewriteEngine On

# 1) Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) www -> apex (canonique : agropharmatchad.com)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# 3) Servir les fichiers .html pour les URLs sans extension (clean URLs)
#    /produits  ->  produits.html   ·   /produits/semences-maraicheres -> .../semences-maraicheres.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4) Page 404 personnalisée (générée par Next : 404.html)
ErrorDocument 404 /404.html

# 5) Cache long pour les assets immuables de Next (_next/static)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
