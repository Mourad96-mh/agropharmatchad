# AGROPHARMA TCHAD — hébergement statique (Hostinger / LiteSpeed / Apache)
# Export statique Next.js : URLs sans slash final (ex: /produits/semences-maraicheres)

Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# 1) Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) www -> apex (canonique : agropharmatchad.com)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# 3) Clean URLs : servir X.html pour /X dès que le fichier existe.
#    (on ne teste PAS !-d : /produits est à la fois un dossier ET produits.html —
#     on veut servir produits.html, donc on vérifie seulement que la requête n'est pas déjà un fichier)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4) Page 404 personnalisée (Next génère 404.html)
ErrorDocument 404 /404.html

# 5) Cache long pour les assets immuables de Next
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
